HARBOR_ENV=
HARBOR_API_PORT=

# Service composition flags (see services/api). Migrations and the API server
# run by default; the indexer, agent refresh/scoring, and keeper are opt-in so
# each can run as its own process during local development.
HARBOR_RUN_MIGRATIONS=true
HARBOR_RUN_API=true
HARBOR_RUN_INDEXER=false
HARBOR_RUN_XRPL_OBSERVER=false
HARBOR_RUN_AGENT_REFRESH=false
HARBOR_RUN_KEEPER=false

# API server. Comma-separated allowed CORS origins (default: the local Next.js
# dev server at http://localhost:3000 and http://127.0.0.1:3000). Use "*" to
# allow any origin. Build metadata is surfaced by GET /health.
HARBOR_API_CORS_ORIGINS=
HARBOR_BUILD_VERSION=
HARBOR_BUILD_COMMIT=

RPC_URL_COSTON2=
DEPLOYER_PRIVATE_KEY=
KEEPER_EXECUTOR_ADDRESS=
HARBOR_ASSET_MANAGER_OR_REGISTRY_ADDRESS=
HARBOR_ASSET_MANAGER_ADDRESS=
HARBOR_RESOLVE_ASSET_MANAGER_FROM_REGISTRY=true
HARBOR_OWNER_ADDRESS=
INDEXER_DB_URL=./data/harbor.sqlite
HARBOR_AGENT_INVENTORY_PAGE_SIZE=
HARBOR_AGENT_REFRESH_INTERVAL_MS=300000
HARBOR_FTSO_V2_ADDRESS=
HARBOR_FTSO_MAX_AGE_SECONDS=3600
XRPL_ENDPOINT=
FDC_DA_LAYER_URL=
RPC_API_KEY_COSTON2=
XRPL_API_KEY=
FDC_DA_LAYER_API_KEY=
KEEPER_PRIVATE_KEY=
HARBOR_REDEEMER_ADDRESS=
HARBOR_KEEPER_POLL_INTERVAL_MS=30000
HARBOR_KEEPER_BATCH_SIZE=25
HARBOR_FDC_MESSAGE_INTEGRITY_CODE=

NEXT_PUBLIC_RPC_URL_COSTON2=
NEXT_PUBLIC_HARBOR_API_URL=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_HARBOR_CONTRACT_ADDRESS=
# Native executor fee (wei) attached to redeem when the Harbor keeper is the
# executor. Defaults to 0.1 C2FLR (100000000000000000). Only sent when
# NEXT_PUBLIC_HARBOR_CONTRACT_ADDRESS is configured.
NEXT_PUBLIC_HARBOR_EXECUTOR_FEE_WEI=

# --- FAssets indexer durability (added to fix frozen redemption status) ---
# The indexer now backfills missed on-chain events from a persisted cursor on a
# poll loop, so events emitted during a restart/redeploy/RPC gap are recovered
# instead of lost. Tune the range to your RPC's eth_getLogs limit.
#
# Max blocks per eth_getLogs request. Public Coston2 RPC caps this at 30, so the
# default is 30. Raise it only if your RPC allows larger ranges.
HARBOR_INDEXER_MAX_BLOCK_RANGE=30
# Reconciliation poll cadence in milliseconds (default 10000).
HARBOR_INDEXER_POLL_INTERVAL_MS=10000
# Optional explicit block to start indexing from on first run (no cursor yet).
# Set this to your AssetManager/HarborRedeemer deployment block for a complete
# history. If unset, the indexer starts HARBOR_INDEXER_START_LOOKBACK blocks
# behind the current head.
HARBOR_INDEXER_START_BLOCK=
# How far behind the current head to start when HARBOR_INDEXER_START_BLOCK is
# unset and no cursor exists yet (default 5000).
HARBOR_INDEXER_START_LOOKBACK=5000
# Keep the low-latency live event watch alongside the backfill reconciler
# (default true). The reconciler alone is sufficient for correctness.
HARBOR_INDEXER_WATCH=true

# --- XRPL payment observer (set HARBOR_RUN_XRPL_OBSERVER=true to enable) ---
# Polls the redeemer's XRPL underlying address for the agent's payment and
# records a settlement receipt, giving a fast XRPL-sourced settlement signal.
# Uses XRPL_ENDPOINT (falls back to the public testnet WSS endpoint).
HARBOR_XRPL_OBSERVER_POLL_INTERVAL_MS=15000
HARBOR_XRPL_OBSERVER_BATCH_SIZE=25
