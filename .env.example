HARBOR_ENV=
HARBOR_API_PORT=

# Service composition flags (see services/api). Migrations and the API server
# run by default; the indexer, agent refresh/scoring, and keeper are opt-in so
# each can run as its own process during local development.
HARBOR_RUN_MIGRATIONS=true
HARBOR_RUN_API=true
HARBOR_RUN_INDEXER=false
HARBOR_RUN_AGENT_REFRESH=false
HARBOR_RUN_KEEPER=false

# API server. Comma-separated allowed CORS origins (default: the local Next.js
# dev server at http://localhost:3000 and http://127.0.0.1:3000). Use "*" to
# allow any origin. Build metadata is surfaced by GET /health.
HARBOR_API_CORS_ORIGINS=
HARBOR_BUILD_VERSION=
HARBOR_BUILD_COMMIT=

RPC_URL_COSTON2=
DEPLOYER_PRIVATE_KEY=
KEEPER_EXECUTOR_ADDRESS=
HARBOR_ASSET_MANAGER_OR_REGISTRY_ADDRESS=
HARBOR_ASSET_MANAGER_ADDRESS=
HARBOR_RESOLVE_ASSET_MANAGER_FROM_REGISTRY=true
HARBOR_OWNER_ADDRESS=
INDEXER_DB_URL=./data/harbor.sqlite
HARBOR_AGENT_INVENTORY_PAGE_SIZE=
HARBOR_AGENT_REFRESH_INTERVAL_MS=300000
HARBOR_FTSO_V2_ADDRESS=
HARBOR_FTSO_MAX_AGE_SECONDS=3600
XRPL_ENDPOINT=
FDC_DA_LAYER_URL=
RPC_API_KEY_COSTON2=
XRPL_API_KEY=
FDC_DA_LAYER_API_KEY=
KEEPER_PRIVATE_KEY=
HARBOR_REDEEMER_ADDRESS=
HARBOR_KEEPER_POLL_INTERVAL_MS=30000
HARBOR_KEEPER_BATCH_SIZE=25
HARBOR_FDC_MESSAGE_INTEGRITY_CODE=

NEXT_PUBLIC_RPC_URL_COSTON2=
NEXT_PUBLIC_HARBOR_API_URL=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_HARBOR_CONTRACT_ADDRESS=
