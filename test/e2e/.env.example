# Harbor E2E — configuration reference.
# Every value below is OPTIONAL: the suite ships with verified Coston2 testnet
# defaults baked into CFG (see harbor-e2e.ts). Override any of them via the
# environment. Copy to `.env` and edit, or just export inline before the run.
#
#   RUN_MUTATIONS=true npx tsx harbor-e2e.ts
#
# TESTNET ONLY. Supply your own throwaway Coston2 key via the environment; no
# key is bundled with this file. Never commit a private key or fund the address
# with anything of value.

# ── Network ────────────────────────────────────────────────────────────────
RPC_URL=https://coston2-api.flare.network/ext/C/rpc
# Coston2 throwaway signer (owner + defaultKeeperExecutor of the Harbor executor).
# Leave blank here and provide it via your shell or a git-ignored .env before the
# run:  export PRIVATE_KEY=0x<your-throwaway-key>
# SECURITY: the value previously committed here has been treated as compromised
# and ROTATED/revoked. Do not attempt to reuse it. Never commit a real key.
PRIVATE_KEY=

# Redeemer's XRPL classic address (where the agent must pay on XRPL)
XRPL_REDEEMER_ADDRESS=rDc7pHdFxCa9gVgXrfipWVU4HsXqtUNC8G

# ── FDC (Flare Data Connector) ───────────────────────────────────────────────
FDC_VERIFIER_BASE=https://fdc-verifiers-testnet.flare.network/verifier/xrp
FDC_DA_LAYER_BASE=https://ctn2-data-availability.flare.network
FDC_API_KEY=00000000-0000-0000-0000-000000000000        # public testnet key

# ── Redemption / executor ────────────────────────────────────────────────────
HARBOR_EXECUTOR_FEE_WEI=100000000000000000               # 0.1 C2FLR
LOTS_TO_REDEEM=1                                         # 1 lot = 10 FXRP (10_000_000 UBA)

# ── Redeem-by-tag (harbor-tag-e2e.ts) ───────────────────────────────────────
# Destination tag used by the tag-lane suite (redeemWithTag). Empty/0 still
# selects the tag path; the agent's XRPL payment must carry this exact tag.
TAG_DESTINATION_TAG=12345

# ── Behaviour flags (default: everything read-only / off) ────────────────────
RUN_MUTATIONS=false        # send state-changing txs (approve/redeem, executeDefault, …)
RUN_FDC_PROOF=false        # run the full FDC proof pipeline live (~3-6 min, ~1000 wei fee)
RUN_KEEPER_SWEEP=false      # scan recent blocks for a Harbor-nominated, expired, unpaid default
KEEPER_SWEEP_LOOKBACK=9000  # blocks to scan for the keeper sweep (and id lookups)

# Set to a genuinely-defaulted (unpaid, expired, still-open) redemption id to run
# T5c end-to-end on it. Leave empty and T5c is BLOCKED. The suite looks the id up
# by its indexed requestId within KEEPER_SWEEP_LOOKBACK blocks.
HARBOR_DEFAULTED_REQUEST_ID=

# ── Timeouts / polling (ms) ──────────────────────────────────────────────────
PERFORMED_TIMEOUT_MS=240000          # wait for RedemptionPerformed after redeem
FDC_FINALIZATION_TIMEOUT_MS=600000   # wait for the voting round to finalize
DA_LAYER_TIMEOUT_MS=300000           # wait for the DA-layer Merkle proof
POLL_INTERVAL_MS=10000               # poll cadence for the two waits above
