{
  "name": "@harbor/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "pnpm typecheck && pnpm test",
    "agents:refresh": "pnpm build && node dist/indexer/agentInventoryCli.js refresh",
    "agents:score:refresh": "pnpm build && node dist/scoring/agentReliabilityCli.js refresh",
    "db:create": "pnpm build && node dist/db/cli.js create",
    "db:migrate": "pnpm build && node dist/db/cli.js migrate",
    "db:reset": "pnpm build && node dist/db/cli.js reset",
    "dev": "pnpm build && node dist/index.js",
    "health": "pnpm build && node dist/health.js",
    "keeper:once": "pnpm build && node dist/keeper/cli.js once",
    "keeper:run": "pnpm build && node dist/keeper/cli.js run",
    "start": "node dist/index.js",
    "lint": "pnpm typecheck",
    "test": "pnpm build && node --test \"dist/**/*.test.js\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@harbor/protocol": "workspace:*",
    "@harbor/shared": "workspace:*",
    "better-sqlite3": "^12.11.1",
    "viem": "^2.54.6",
    "xrpl": "^2.14.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "fast-check": "^4.9.0"
  }
}
