{
  "name": "@harbor/protocol",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "pnpm typecheck && pnpm test && pnpm check:harbor-abi",
    "check:harbor-abi": "pnpm build && node scripts/check-harbor-abi.mjs",
    "generate:harbor-abi": "node scripts/export-harbor-abi.mjs",
    "lint": "pnpm typecheck",
    "test": "pnpm build && node --test \"dist/**/*.test.js\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
